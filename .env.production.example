# 生产环境配置（复制为 .env 并修改）
DJANGO_ENV=production

# 必须替换成随机生成的密钥（python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"）
DJANGO_SECRET_KEY=replace-with-random-secret-key

# 允许访问的域名，多个用逗号分隔
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,服务器IP

# 生产环境必须关闭
DEBUG=False

# 调试日志关闭
DEBUG_LOG_API=False

# 通知开关
ENABLE_NOTIFICATIONS=True

# SMTP 邮件配置
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=1346383068@qq.com
EMAIL_HOST_PASSWORD=zhihong1008
DEFAULT_FROM_EMAIL=Ziqiang Academy <1346383068@qq.com>

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=zqkxjsbnb666
ADMIN_EMAIL=admin@your-domain.com

# CORS 允许的前端域名
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# CSRF 信任的域名
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
