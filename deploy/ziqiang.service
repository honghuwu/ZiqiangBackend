[Unit]
Description=Ziqiang Academy Backend
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/ziqiang
EnvironmentFile=/opt/ziqiang/.env
ExecStart=/opt/ziqiang/venv/bin/gunicorn core.wsgi:application --config /opt/ziqiang/deploy/gunicorn.conf.py
ExecReload=/bin/kill -s HUP $MAINPID
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
