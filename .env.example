# Django 运行环境。
# 本地开发建议使用 `local`，常见可选值还有 `staging`、`production`。
DJANGO_ENV=local

# Django 使用的密钥。
# 在非本地环境中请务必替换成你自己的值。
DJANGO_SECRET_KEY=replace-with-your-own-secret-key

# Django 允许访问的主机名，多个值用英文逗号分隔。
# 本地开发示例：
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 可选的 DEBUG 开关。
# 如果不填写：当 `DJANGO_ENV=local` 时默认开启，否则默认关闭。
DEBUG=True

# 是否启用站内通知触发。
# 当前建议默认关闭，等产品确认需要后再打开。
ENABLE_NOTIFICATIONS=False

# 是否打印所有 API 请求/响应内容（调试用，仅开发环境）
DEBUG_LOG_API=True

# 邮件后端。
# 开发阶段如果不想真实发邮件，可以保留控制台后端。
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP 邮件服务器配置。
# 如果要真实发邮件，请把 `EMAIL_BACKEND` 改为：
# django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password

# 发信人地址，显示在邮件发送方。
DEFAULT_FROM_EMAIL=Ziqiang Academy <noreply@example.com>

# 管理员账号配置（仅首次启动时用于创建管理员账号）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@example.com

CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
